# ── Server ─────────────────────────────────────────────
APP_ENV=development
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s

# ── PostgreSQL ─────────────────────────────────────────
DATABASE_URL=postgres://wearwhere:wearwhere@localhost:5432/wearwhere?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# ── Redis ──────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h   # 30 days

# ── SMTP (email OTP / reset link) ─────────────────────
# For Gmail: enable 2FA and create an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_EMAIL=no-reply@wearwhere.app
SMTP_FROM_NAME=WearWhere

# ── SMS (Twilio) ───────────────────────────────────────
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── OAuth ──────────────────────────────────────────────
# Leave blank for now; the /auth/oauth/* endpoints will return
# SOCIAL_TOKEN_INVALID until you populate them. Fill in later when ready.
#
# Comma-separated when multiple platforms ship:
#   Google: web Client ID + iOS Client ID
#           (Android uses the web ID as serverClientId, so its tokens also carry aud=Web ID)
#   Apple:  Services ID (web + Android via web flow) + App Bundle ID (native iOS)
# Legacy single-value vars GOOGLE_CLIENT_ID / APPLE_CLIENT_ID are still honored.
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_IDS=

# ── Rate limit / brute force ──────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
OTP_TTL_MINUTES=15
OTP_MAX_PER_HOUR=3
RATE_LIMIT_PER_MIN=100

# ── PayOS payment gateway ──────────────────────────────
PAYOS_MODE=mock                              # mock|production
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=http://localhost:3000/checkout/success
PAYOS_CANCEL_URL=http://localhost:3000/checkout/cancel
PAYOS_BASE_URL=http://localhost:8080

# ── Shipping ───────────────────────────────────────────
SHIPPING_PROVIDER=flat

# ── Reservation timeout for PayOS pending orders ──────
RESERVATION_TIMEOUT_MINUTES=30
RESERVATION_CLEANUP_INTERVAL=5m
